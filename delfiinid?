<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>Magical Dolphin Ocean</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
    }

    html,body{
        width:100%;
        height:100%;
        overflow:hidden;
        background:#000;
        cursor:crosshair;
        font-family:sans-serif;
    }

    #scene{
        position:relative;
        width:100vw;
        height:100vh;
        overflow:hidden;
    }

    /* BACKGROUND IMAGE */
    #bg{
        position:absolute;
        inset:0;
        width:100%;
        height:100%;
        object-fit:cover;
        z-index:1;
        pointer-events:none;
        user-select:none;
    }

    /* DOLPHIN LAYER */
    #dolphins{
        position:absolute;
        inset:0;
        z-index:2;
        pointer-events:none;
    }

    /* SPARKLE CANVAS */
    canvas{
        position:absolute;
        inset:0;
        width:100%;
        height:100%;
        z-index:3;
        pointer-events:none;
    }

    /* FLOATING DOLPHINS */
    .dolphin{
        position:absolute;
        font-size:70px;
        opacity:0.8;
        filter:
            drop-shadow(0 0 10px rgba(255,255,255,0.8))
            drop-shadow(0 0 20px rgba(0,255,255,0.6));
        animation:float linear infinite;
        user-select:none;
    }

    @keyframes float{
        from{
            transform:
                translateX(-200px)
                translateY(0px)
                rotate(0deg);
        }

        25%{
            transform:
                translateX(25vw)
                translateY(-40px)
                rotate(-5deg);
        }

        50%{
            transform:
                translateX(50vw)
                translateY(20px)
                rotate(5deg);
        }

        75%{
            transform:
                translateX(75vw)
                translateY(-30px)
                rotate(-3deg);
        }

        to{
            transform:
                translateX(120vw)
                translateY(0px)
                rotate(0deg);
        }
    }

</style>
</head>

<body>

<div id="scene">

    <!-- REPLACE THIS WITH YOUR IMAGE FILE -->
    <img id="bg" src="background.jpg" alt="Fantasy Ocean">

    <!-- FLOATING DOLPHINS -->
    <div id="dolphins">

        <div class="dolphin"
            style="
                top:12%;
                animation-duration:18s;
                animation-delay:-2s;
            ">
            🐬
        </div>

        <div class="dolphin"
            style="
                top:35%;
                font-size:90px;
                animation-duration:24s;
                animation-delay:-10s;
                opacity:0.7;
            ">
            🐬
        </div>

        <div class="dolphin"
            style="
                top:62%;
                font-size:60px;
                animation-duration:20s;
                animation-delay:-5s;
                opacity:0.6;
            ">
            🐬
        </div>

        <div class="dolphin"
            style="
                top:78%;
                font-size:80px;
                animation-duration:28s;
                animation-delay:-15s;
                opacity:0.5;
            ">
            🐬
        </div>

    </div>

    <!-- SPARKLES -->
    <canvas id="sparkleCanvas"></canvas>

</div>

<script>

const canvas = document.getElementById("sparkleCanvas");
const ctx = canvas.getContext("2d");

let width, height;

function resizeCanvas(){
    width = canvas.width = window.innerWidth;
    height = canvas.height = window.innerHeight;
}

resizeCanvas();
window.addEventListener("resize", resizeCanvas);

const sparkles = [];

/* SPARKLE CLASS */
class Sparkle{

    constructor(x,y){

        this.x = x;
        this.y = y;

        this.size = Math.random() * 4 + 1;

        this.life = 0;
        this.maxLife = Math.random() * 50 + 40;

        this.vx = (Math.random() - 0.5) * 2;
        this.vy = (Math.random() - 0.5) * 2;

        this.opacity = 1;

        this.hue = 180 + Math.random() * 80;
    }

    update(){

        this.life++;

        this.x += this.vx;
        this.y += this.vy;

        this.opacity = 1 - this.life / this.maxLife;
    }

    draw(){

        ctx.save();

        ctx.translate(this.x, this.y);

        /* GLOW */
        const gradient = ctx.createRadialGradient(
            0,0,0,
            0,0,this.size * 6
        );

        gradient.addColorStop(
            0,
            `hsla(${this.hue},100%,80%,${this.opacity})`
        );

        gradient.addColorStop(
            1,
            `hsla(${this.hue},100%,80%,0)`
        );

        ctx.fillStyle = gradient;

        ctx.beginPath();
        ctx.arc(0,0,this.size * 6,0,Math.PI*2);
        ctx.fill();

        /* STAR SHAPE */
        ctx.strokeStyle = `rgba(255,255,255,${this.opacity})`;
        ctx.lineWidth = 1.5;

        ctx.beginPath();

        ctx.moveTo(-this.size,0);
        ctx.lineTo(this.size,0);

        ctx.moveTo(0,-this.size);
        ctx.lineTo(0,this.size);

        ctx.stroke();

        ctx.restore();
    }
}

/* CREATE SPARKLES */
function createSparkles(x,y){

    for(let i=0;i<6;i++){

        sparkles.push(new Sparkle(x,y));
    }
}

/* MOUSE */
window.addEventListener("mousemove",(e)=>{

    createSparkles(e.clientX,e.clientY);
});

/* TOUCH */
window.addEventListener("touchmove",(e)=>{

    const touch = e.touches[0];

    createSparkles(touch.clientX,touch.clientY);
});

/* ANIMATION LOOP */
function animate(){

    ctx.clearRect(0,0,width,height);

    for(let i=sparkles.length-1;i>=0;i--){

        const sparkle = sparkles[i];

        sparkle.update();
        sparkle.draw();

        if(sparkle.life >= sparkle.maxLife){

            sparkles.splice(i,1);
        }
    }

    requestAnimationFrame(animate);
}

animate();

</script>

</body>
</html>
