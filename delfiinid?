<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Sunset Sea Dreamscape</title>

<style>
    html, body {
        margin: 0;
        overflow: hidden;
        width: 100%;
        height: 100%;
        background: #000;
        font-family: Arial, sans-serif;
    }

    canvas {
        display: block;
    }

    .overlay {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
            radial-gradient(circle at 50% 70%, rgba(255,140,0,0.12), transparent 45%),
            linear-gradient(to bottom,
                rgba(255,255,255,0.03),
                rgba(0,0,0,0.15));
        mix-blend-mode: screen;
    }

    .title {
        position: absolute;
        top: 40px;
        width: 100%;
        text-align: center;
        color: rgba(255,255,255,0.9);
        font-size: 2rem;
        letter-spacing: 4px;
        text-shadow:
            0 0 10px rgba(255,255,255,0.4),
            0 0 30px rgba(255,180,100,0.4);
        pointer-events: none;
    }
</style>
</head>

<body>

<div class="title">SUNSET SEA</div>
<div class="overlay"></div>

<canvas id="scene"></canvas>

<script>
const canvas = document.getElementById("scene");
const ctx = canvas.getContext("2d");

let w, h;
let time = 0;

const sparkles = [];
const clouds = [];
const stars = [];

function resize() {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;

    createClouds();
}

window.addEventListener("resize", resize);
resize();

class Cloud {
    constructor(x, y, size, speed, alpha) {
        this.x = x;
        this.y = y;
        this.size = size;
        this.speed = speed;
        this.alpha = alpha;
    }

    draw() {
        ctx.save();
        ctx.globalAlpha = this.alpha;

        for (let i = 0; i < 18; i++) {
            const ox = Math.sin(i * 1.8) * this.size * 0.6;
            const oy = Math.cos(i * 2.3) * this.size * 0.15;

            const grad = ctx.createRadialGradient(
                this.x + ox,
                this.y + oy,
                0,
                this.x + ox,
                this.y + oy,
                this.size
            );

            grad.addColorStop(0, "rgba(255,255,255,0.95)");
            grad.addColorStop(0.5, "rgba(255,210,180,0.55)");
            grad.addColorStop(1, "rgba(255,170,120,0)");

            ctx.fillStyle = grad;

            ctx.beginPath();
            ctx.arc(
                this.x + ox,
                this.y + oy,
                this.size * (0.5 + Math.random() * 0.2),
                0,
                Math.PI * 2
            );
            ctx.fill();
        }

        ctx.restore();

        this.x += this.speed;

        if (this.x - this.size > w) {
            this.x = -200;
        }
    }
}

function createClouds() {
    clouds.length = 0;

    for (let i = 0; i < 20; i++) {
        clouds.push(
            new Cloud(
                Math.random() * w,
                Math.random() * h * 0.45,
                50 + Math.random() * 80,
                0.05 + Math.random() * 0.15,
                0.12 + Math.random() * 0.18
            )
        );
    }
}

class Sparkle {
    constructor(x, y) {
        this.x = x;
        this.y = y;
        this.life = 1;
        this.size = 2 + Math.random() * 3;
        this.vx = (Math.random() - 0.5) * 2;
        this.vy = (Math.random() - 0.5) * 2;
        this.hue = 40 + Math.random() * 30;
    }

    update() {
        this.x += this.vx;
        this.y += this.vy;
        this.life -= 0.02;
    }

    draw() {
        ctx.save();
        ctx.globalAlpha = this.life;

        ctx.shadowBlur = 15;
        ctx.shadowColor = `hsla(${this.hue},100%,70%,1)`;

        ctx.fillStyle = `hsla(${this.hue},100%,75%,1)`;

        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fill();

        ctx.restore();
    }
}

window.addEventListener("mousemove", (e) => {
    for (let i = 0; i < 4; i++) {
        sparkles.push(
            new Sparkle(
                e.clientX + (Math.random() - 0.5) * 20,
                e.clientY + (Math.random() - 0.5) * 20
            )
        );
    }
});

function drawSky() {
    const sky = ctx.createLinearGradient(0, 0, 0, h);

    sky.addColorStop(0, "#07111f");
    sky.addColorStop(0.25, "#253c6b");
    sky.addColorStop(0.5, "#ff925e");
    sky.addColorStop(0.7, "#ffb57d");
    sky.addColorStop(1, "#1a3550");

    ctx.fillStyle = sky;
    ctx.fillRect(0, 0, w, h);
}

function drawSun() {
    const x = w / 2;
    const y = h * 0.58;

    const glow = ctx.createRadialGradient(x, y, 20, x, y, 180);

    glow.addColorStop(0, "rgba(255,240,200,1)");
    glow.addColorStop(0.2, "rgba(255,200,120,0.9)");
    glow.addColorStop(0.5, "rgba(255,120,50,0.35)");
    glow.addColorStop(1, "rgba(255,120,50,0)");

    ctx.fillStyle = glow;

    ctx.beginPath();
    ctx.arc(x, y, 180, 0, Math.PI * 2);
    ctx.fill();

    ctx.beginPath();
    ctx.fillStyle = "#fff5c0";
    ctx.arc(x, y, 55, 0, Math.PI * 2);
    ctx.fill();
}

function drawSea() {
    const seaTop = h * 0.58;

    const seaGrad = ctx.createLinearGradient(0, seaTop, 0, h);

    seaGrad.addColorStop(0, "#ff8f5a");
    seaGrad.addColorStop(0.15, "#285a7a");
    seaGrad.addColorStop(1, "#06151f");

    ctx.fillStyle = seaGrad;
    ctx.fillRect(0, seaTop, w, h - seaTop);

    for (let y = seaTop; y < h; y += 3) {
        const wave =
            Math.sin(y * 0.03 + time * 1.2) * 10;

        ctx.strokeStyle = `rgba(255,255,255,${
            0.03 + (y - seaTop) / h * 0.05
        })`;

        ctx.beginPath();

        for (let x = 0; x < w; x += 12) {
            const yy =
                y +
                Math.sin(x * 0.018 + time + y * 0.02) * 3 +
                wave * 0.2;

            if (x === 0) ctx.moveTo(x, yy);
            else ctx.lineTo(x, yy);
        }

        ctx.stroke();
    }

    // reflection
    const reflect = ctx.createLinearGradient(
        w/2,
        seaTop,
        w/2,
        h
    );

    reflect.addColorStop(0, "rgba(255,220,150,0.5)");
    reflect.addColorStop(1, "rgba(255,220,150,0)");

    ctx.fillStyle = reflect;

    ctx.beginPath();
    ctx.moveTo(w/2 - 50, seaTop);
    ctx.lineTo(w/2 + 50, seaTop);
    ctx.lineTo(w/2 + 250, h);
    ctx.lineTo(w/2 - 250, h);
    ctx.closePath();
    ctx.fill();
}

function drawAtmosphere() {
    const mist = ctx.createLinearGradient(0, h*0.45, 0, h);

    mist.addColorStop(0, "rgba(255,180,120,0)");
    mist.addColorStop(1, "rgba(255,160,120,0.12)");

    ctx.fillStyle = mist;
    ctx.fillRect(0, 0, w, h);
}

function animate() {
    requestAnimationFrame(animate);

    time += 0.005;

    drawSky();
    drawSun();

    clouds.forEach(c => c.draw());

    drawSea();
    drawAtmosphere();

    for (let i = sparkles.length - 1; i >= 0; i--) {
        sparkles[i].update();
        sparkles[i].draw();

        if (sparkles[i].life <= 0) {
            sparkles.splice(i, 1);
        }
    }

    // cinematic glow
    ctx.fillStyle = "rgba(255,120,50,0.03)";
    ctx.fillRect(0,0,w,h);
}

animate();
</script>

</body>
</html>